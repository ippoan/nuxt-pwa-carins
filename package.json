{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev --tunnel",
    "generate": "nuxt generate",
    "preview": "PWA_TITLE=staging stage=preview nuxt build && wrangler pages deploy dist/ --branch preview",
    "publish": "nuxt build && wrangler pages deploy dist/ --branch production",
    "deploy": "NITRO_PRESET=cloudflare_module nuxt build && wrangler deploy",
    "deployWatch": "NITRO_PRESET=cloudflare_module nuxt build && wrangler deploy && wrangler tail nuxt-pwa-carins",
    "postinstall": "nuxt prepare"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.10.2",
    "@connectrpc/connect": "^2.1.1",
    "@connectrpc/connect-node": "^2.1.1",
    "@connectrpc/connect-web": "^2.1.1",
    "@nuxt/ui": "2.20.0",
    "@vueuse/core": "^12.3.0",
    "@vueuse/nuxt": "^12.3.0",
    "@yhonda-ohishi-pub-dev/logi-proto": "^0.1.1",
    "nuxt": "^3.15.1",
    "nuxt-api-party": "2.1.2",
    "openapi-typescript": "^5 || ^6 || ^7",
    "typescript": "^5.7.3",
    "vue": "latest",
    "vue-router": "latest"
  },
  "devDependencies": {
    "@vite-pwa/assets-generator": "^0.2.6",
    "@vite-pwa/nuxt": "^0.10.6",
    "playwright": "^1.58.1",
    "wrangler": "^3.100.0"
  }
}
