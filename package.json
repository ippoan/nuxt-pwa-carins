{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev --tunnel",
    "generate": "nuxt generate",
    "preview": "PWA_TITLE=staging stage=preview nuxt build && wrangler pages deploy dist/ --branch preview",
    "publish": "nuxt build && wrangler pages deploy dist/ --branch production",
    "deploy": "NITRO_PRESET=cloudflare_module nuxt build && wrangler deploy",
    "deployWatch": "NITRO_PRESET=cloudflare_module nuxt build && wrangler deploy && wrangler tail nuxt-pwa-carins",
    "postinstall": "nuxt prepare",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@ippoan/auth-client": "^0.1.6",
    "@nuxt/ui": "2.20.0",
    "@vueuse/core": "^12.3.0",
    "@vueuse/nuxt": "^12.3.0",
    "nuxt": "^3.15.1",
    "nuxt-api-party": "2.1.2",
    "openapi-typescript": "^5 || ^6 || ^7",
    "typescript": "^5.7.3",
    "vue": "latest",
    "vue-router": "latest"
  },
  "devDependencies": {
    "@nuxt/test-utils": "^4.0.0",
    "@vite-pwa/assets-generator": "^0.2.6",
    "@vite-pwa/nuxt": "^0.10.6",
    "@vitest/coverage-v8": "^4.1.2",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.8.9",
    "playwright": "^1.58.1",
    "vitest": "^4.1.2",
    "wrangler": "^4.67.0"
  }
}
